---
import site from "../data/site";
import { withBase } from "../lib/url";

const { product } = Astro.props;

const hasBadge = product.badge && product.badge.length > 0;

// WhatsApp enquiry kept for later; contact reference now points to Instagram.
// const enquireMessage = "Hi! I'm interested in the " + product.name + ". Could you share more details?";
// const enquireLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(enquireMessage)}`;
const enquireLink = site.instagram;
const orderNowLink = "https://docs.google.com/forms/d/e/1FAIpQLSe-Cn6l8ntsumC6LPdek-n2_3XnO-UZ8tu1f7YTg2Q95hjjxw/viewform"

// Which part of the image stays visible inside the cropped 4:3 thumbnail.
// Optional per product; defaults to centre. Accepts any CSS object-position
// value, e.g. "top", "center", "left bottom", or percentages like "50% 25%".
const imagePosition = product.imagePosition || "center";
---

<div class="product-card">

  {hasBadge && (
    <div class="badge">
      {product.badge}
    </div>
  )}

  <div class="image-wrapper">
    <img
      src={withBase(product.image)}
      alt={product.name}
      loading="lazy"
      style={`object-position:${imagePosition}`}
      data-zoomable
      role="button"
      tabindex="0"
      aria-label={`Enlarge image of ${product.name}`}
    />
  </div>

  <div class="content">

    <span class="category">
      {product.category}
    </span>

    <h3>
      {product.name}
    </h3>

    <p class="description">
      {product.shortDescription}
    </p>

    <div class="prices">

      {
        product.prices.map((price) => (
          <div class="price-row">

            <span>
              {price.label}
            </span>

            <strong>
              €{price.value}
            </strong>

          </div>
        ))
      }

    </div>

    <div class="actions">
      <a class="enquire-btn" href={enquireLink} target="_blank" rel="noopener">
        Enquire Now
      </a>
      <a class="ordernow-btn" href={orderNowLink} target="_blank" rel="noopener">
        Order Now
      </a>
    </div>

  </div>

</div>

<style>

.product-card{

position:relative;

background:#fff;

border-radius:22px;

overflow:hidden;

box-shadow:0 15px 40px rgba(0,0,0,.08);

transition:.3s;

display:flex;

flex-direction:column;

height:100%;

}

.product-card:hover{

transform:translateY(-8px);

box-shadow:0 25px 50px rgba(0,0,0,.12);

}

.image-wrapper{

aspect-ratio:4 / 3;

overflow:hidden;

background:#f3efe9;

}

.image-wrapper img{

width:100%;

height:100%;

object-fit:cover;

transition:.5s;

cursor:zoom-in;

}

.product-card:hover img{

transform:scale(1.05);

}

.badge{

position:absolute;

top:16px;

right:16px;

background:#C9A46C;

color:white;

padding:8px 14px;

border-radius:999px;

font-size:.75rem;

font-weight:600;

letter-spacing:.5px;

z-index:5;

}

.content{

padding:24px;

display:flex;

flex-direction:column;

flex:1;

}

.category{

font-size:.8rem;

text-transform:uppercase;

letter-spacing:2px;

color:#999;

margin-bottom:8px;

}

h3{

font-size:2rem;

margin-bottom:10px;

line-height:1.1;

}

.description{

color:#666;

font-size:.95rem;

margin-bottom:22px;

min-height:60px;

}

.prices{

display:flex;

flex-direction:column;

gap:10px;

margin-bottom:28px;

}

.price-row{

display:flex;

justify-content:space-between;

align-items:center;

padding-bottom:8px;

border-bottom:1px solid #eee;

}

.price-row strong{

font-size:1.1rem;

color:#C9A46C;

}

.actions{

margin-top:auto;

display:flex;

gap:12px;

}

.enquire-btn{

flex:1;

display:block;

padding:15px 12px;

border:none;

border-radius:999px;

background:#2F2F2F;

color:white;

cursor:pointer;

font-weight:600;

font-size:.92rem;

text-align:center;

text-decoration:none;

white-space:nowrap;

transition:.3s;

}

.enquire-btn:hover{

background:#C9A46C;

}


.ordernow-btn{

flex:1;

display:block;

padding:15px 12px;

border:none;

border-radius:999px;

background:#C9A46C;

color:white;

cursor:pointer;

font-weight:600;

font-size:.92rem;

text-align:center;

text-decoration:none;

white-space:nowrap;

transition:.3s;

}

.ordernow-btn:hover{

background:#2F2F2F;

}

@media(max-width:768px){

h3{

font-size:1.7rem;

}

}

</style>
